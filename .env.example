# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=Nexus Platform
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Authentication
NEXT_PUBLIC_JWT_EXPIRY=3600
SESSION_SECRET=your_session_secret_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/nexus_platform

# Encryption
ENCRYPTION_KEY=your_encryption_key_here

# Email (SMTP Configuration)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=noreply@nexus-platform.com

# AWS S3 (Optional - if using S3 for document storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Monitoring & Analytics
SENTRY_DSN=
ANALYTICS_ID=

# Third-party Integrations
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
WEBHOOK_SECRET=

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
FEATURE_DOCUMENT_AI=false
FEATURE_ADVANCED_ANALYTICS=false
FEATURE_DARK_MODE=true

# Cache Configuration
CACHE_TTL=3600
REDIS_URL=

# Timezone
TZ=UTC
